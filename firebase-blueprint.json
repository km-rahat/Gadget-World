{
  "entities": {
    "User": {
      "title": "User",
      "description": "Authenticated user profile documents",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Standard invoice and dispatch document details",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "totalAmount": { "type": "number" },
        "estimatedDelivery": { "type": "string" },
        "notes": { "type": "string" },
        "orderDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "customerName", "phone", "email", "address", "paymentMethod", "totalAmount"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles collection"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Order records database collection"
    }
  }
}

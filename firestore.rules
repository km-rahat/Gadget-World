rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'rahatboss015@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Collection: Users
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      
      allow create: if isOwner(userId) 
                    && (
                      request.resource.data.role == 'customer' || 
                      (request.resource.data.role == 'admin' && request.auth.token.email == 'rahatboss015@gmail.com')
                    );
                    
      allow update: if isAdmin() || (
                      isOwner(userId) && 
                      (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
                    );
      
      allow delete: if isAdmin();
    }

    // Collection: Orders
    match /orders/{orderId} {
      // Create is open to authenticated users and guest checkout
      allow create: if true;
      
      // Get is open for tracking/receipt displays; lists are restricted
      allow get: if true;
      allow list: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
      
      // Update is restricted exclusively to Admin (e.g. for status changes)
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Collection: Products (Dynamic Inventory Management)
    match /products/{productId} {
      // Anyone can browse products
      allow read: if true;
      
      // Only admins can add, update, or remove products
      allow write: if isAdmin();
    }
  }
}

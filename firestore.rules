rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Collection: Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) 
                    && request.resource.data.keys().hasAll(['uid', 'fullName', 'email'])
                    && request.resource.data.uid == userId;
      allow update: if isOwner(userId)
                    && request.resource.data.uid == userId;
      allow delete: if false; // Profiles cannot be deleted directly from client SDK
    }

    // Collection: Orders
    match /orders/{orderId} {
      // Anyone can submit an order (registered or checkout guest)
      allow create: if request.resource.data.keys().hasAll(['orderId', 'customerName', 'phone', 'email', 'address', 'paymentMethod', 'totalAmount']);
      
      // But only the owner matching email or the authorized user can view or update their orders
      allow get: if true; // Support order confirmation search
      allow list: if isSignedIn() && (resource.data.email == request.auth.token.email);
      allow update, delete: if false; // Orders cannot be modified/removed directly by standard clients
    }
  }
}
